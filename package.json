{
  "name": "markdown77",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform Markdown knowledge base editor.",
  "scripts": {
    "dev": "npm --workspace apps/desktop run dev",
    "dev:web": "npm --workspace apps/desktop run dev:web",
    "build": "npm --workspace apps/desktop run build",
    "package:mac": "bash scripts/package-mac.sh",
    "package:cross": "node scripts/package-platform.mjs",
    "typecheck": "npm --workspace apps/desktop run typecheck"
  },
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "@electron/packager": "^20.0.0"
  }
}
